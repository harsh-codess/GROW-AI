# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# ─── Dependencies ────────────────────────────────────────────────────────────
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# ─── Next.js ─────────────────────────────────────────────────────────────────
/.next/
/out/
/build

# ─── Testing ─────────────────────────────────────────────────────────────────
/coverage

# ─── Environment variables ───────────────────────────────────────────────────
.env
.env.*
!.env.example

# ─── Prisma generated client ─────────────────────────────────────────────────
/lib/generated/

# ─── Local database data (Docker volume) ─────────────────────────────────────
/postgres-data/

# ─── File uploads ────────────────────────────────────────────────────────────
/uploads/
/public/uploads/

# ─── Vercel ──────────────────────────────────────────────────────────────────
.vercel

# ─── TypeScript ──────────────────────────────────────────────────────────────
*.tsbuildinfo
next-env.d.ts

# ─── Logs ────────────────────────────────────────────────────────────────────
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
bun-error.log*
*.log

# ─── OS / Editor ─────────────────────────────────────────────────────────────
.DS_Store
.DS_Store?
Thumbs.db
*.pem

# ─── IDE ─────────────────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo

# ─── Misc ────────────────────────────────────────────────────────────────────
script.sh
repomix-output.txt